%     'ecef');
% 
% fprintf('Saved GNSS dataset with lla2ecef conversion.\n');
% fprintf('Output: %s\n', output_file);
% 
% %% 5. Quick check plot
% figure;
% 
% subplot(2,1,1);
% plot(gps_sow, height);
% grid on;
% title('Height vs GPS Time of Week');
% xlabel('GPS SOW (s)');
% ylabel('Height (m)');
% 
