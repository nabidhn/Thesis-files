% subplot(2,1,1);
% plot(longitude, latitude, 'b', 'LineWidth', 1.5);
% grid on; axis equal;
% title('Trajectory (Horizontal)');
% xlabel('Longitude (deg)'); ylabel('Latitude (deg)');
% 
% subplot(2,1,2);
% plot(utc_datetime, height, 'r');
% grid on; 
% title('Height Profile (UTC Time)');
% xlabel('Time (UTC)'); ylabel('Height (m)');




